generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- КОРИСТУВАЧІ ТА ПРОФІЛЬ---

enum UserRole {
  USER
  ADMIN
}

model User {
  id                      Int       @id @default(autoincrement())
  email                   String    @unique
  username                String    @unique
  password                String    // Зберігаємо хеш пароля
  role                    UserRole  @default(USER)
  
  // --- ПРОФІЛЬ ---
  avatarUrl               String?
  displayName             String?             // Відображуване ім'я
  bio                     String?
  timezone                String?             // Europe/Kyiv - для планування сесій
  language                String?   @default("uk") // Мова інтерфейсу
  
  // --- МЕТА-ДАНІ ---
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  lastActiveAt            DateTime?           // Останній візит

  // 🔐 Ресет пароля
  passwordResetToken      String?   @unique
  passwordResetExpiry     DateTime?

  // Зв'язки
  wallet                  Wallet?   // Один гаманець на юзера
  stats                   UserStats? // Статистика
  
  // Участь у кампаніях та сесіях
  campaignsOwned          Campaign[] @relation("OwnerCampaigns") // Кампанії, де він власник
  campaignMembers         CampaignMember[] // Членство в кампаніях
  sessionsJoined          SessionParticipant[] // Сесії, де він гравець/майстер
  createdSessions         Session[] @relation("CreatedSessions") // Сесії, які він створив
  
  // Заявки на вступ
  joinRequests            JoinRequest[]
  reviewedJoinRequests    JoinRequest[] @relation("ReviewedBy")
  
  // Комунікація
  messages                ChatMessage[] // Повідомлення в чатах
  emailVerified            Boolean   @default(false)
  refreshTokens           RefreshToken[]

  emailVerificationTokens EmailVerificationToken[]
  emailChangeTokens       EmailChangeToken[]
}

model Wallet {
  id      Int     @id @default(autoincrement())
  balance Float   @default(0.0)
  userId  Int     @unique
  user    User    @relation(fields: [userId], references: [id])
  
  transactions Transaction[] // Історія оплат
}

model UserStats {
  id             Int @id @default(autoincrement())
  hoursPlayed    Int @default(0)
  sessionsPlayed Int @default(0)
  userId         Int @unique
  user           User @relation(fields: [userId], references: [id])
}

// --- КАМПАНІЇ ТА СЕСІЇ ---

model Campaign {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String?                           // Обкладинка
  system      String?                           // D&D 5e, Pathfinder, тощо
  
  visibility  CampaignVisibility @default(PRIVATE)
  inviteCode  String?   @unique                // Для LINK_ONLY
  
  ownerId     Int
  owner       User      @relation("OwnerCampaigns", fields: [ownerId], references: [id])
  
  members     CampaignMember[]                 // Учасники кампанії
  sessions    Session[]                        // Кампанія має багато сесій
  joinRequests JoinRequest[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum CampaignVisibility {
  PUBLIC      // Видно в пошуку
  PRIVATE     // Тільки для учасників
  LINK_ONLY   // Доступ за посиланням
}

// === Учасники кампанії ===
model CampaignMember {
  id         Int          @id @default(autoincrement())
  role       CampaignRole @default(PLAYER)
  joinedAt   DateTime     @default(now())
  
  userId     Int
  user       User         @relation(fields: [userId], references: [id])
  
  campaignId Int
  campaign   Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  @@unique([userId, campaignId])
}

enum CampaignRole {
  OWNER
  GM
  PLAYER
}

model Session {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  
  date        DateTime                        // Дата і час початку (UTC)
  duration    Int           @default(180)     // Тривалість в хвилинах
  
  status      SessionStatus @default(PLANNED) // Active, Planned, Finished
  visibility  CampaignVisibility @default(PRIVATE)  // Наслідує від кампанії або окремо
  
  price       Float     @default(0.0)         // Ціна за гру
  maxPlayers  Int       @default(4)
  
  system      String?                         // D&D 5e, Pathfinder 2e, тощо
                                              // Копіюється з кампанії при створенні
                                              // або задається вручну для one-shot
  
  campaignId  Int?                            // Nullable для one-shots
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  
  creatorId   Int                             // Хто створив (GM)
  creator     User      @relation("CreatedSessions", fields: [creatorId], references: [id])
  
  participants SessionParticipant[]
  messages     ChatMessage[]                  // Чат сесії 
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([date, system])                     // Композитний індекс для фільтрації по даті ТА системі
}

// Таблиця зв'язку: Хто є хто в сесії 
model SessionParticipant {
  id        Int              @id @default(autoincrement())
  role      SessionRole      @default(PLAYER)
  status    ParticipantStatus @default(PENDING)  // Підтвердив участь?
  isGuest   Boolean          @default(false)     // Гість (не член кампанії)
  
  userId    Int
  sessionId Int
  
  user      User    @relation(fields: [userId], references: [id])
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId]) // Юзер не може бути двічі в одній грі
}

enum SessionRole {
  GM
  PLAYER
}

enum ParticipantStatus {
  PENDING     // Запрошений, але не підтвердив
  CONFIRMED   // Підтвердив участь
  DECLINED    // Відмовився
  ATTENDED    // Був присутній (після гри)
  NO_SHOW     // Не з'явився
}

// === Заявки на вступ до кампанії ===
model JoinRequest {
  id         Int              @id @default(autoincrement())
  status     JoinRequestStatus @default(PENDING)
  message    String?                           // Повідомлення від заявника
  
  userId     Int
  user       User             @relation(fields: [userId], references: [id])
  
  campaignId Int
  campaign   Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime         @default(now())
  reviewedAt DateTime?
  reviewedBy Int?
  reviewer   User?            @relation("ReviewedBy", fields: [reviewedBy], references: [id])
  
  @@unique([userId, campaignId])
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model EmailVerificationToken {
  id          Int      @id @default(autoincrement())
  token       String   @unique
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

// Токен для зміни email
model EmailChangeToken {
  id          Int      @id @default(autoincrement())
  token       String   @unique
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  newEmail    String   // Новий email, на який надіслано підтвердження
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

// --- КОМУНІКАЦІЯ ТА ФІНАНСИ ---

model ChatMessage {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  
  sessionId Int
  session   Session  @relation(fields: [sessionId], references: [id])
}

model Transaction {
  id        Int      @id @default(autoincrement())
  amount    Float
  type      String   // "DEPOSIT" або "PAYMENT"
  date      DateTime @default(now())
  
  walletId  Int
  wallet    Wallet   @relation(fields: [walletId], references: [id])
}

// --- ENUMS (Списки варіантів) ---

enum SessionStatus {
  PLANNED
  ACTIVE
  FINISHED
  CANCELED
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  revoked    Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
}